# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
# .claude/ 配下は基本的に ignore (会話履歴 / plan ファイル / agent state 等は個人用)。
# ただし `commands/` と `agents/` はチームで versioning したいので exception とする。
.claude/*
!.claude/commands/
!.claude/agents/

# Marketing storyboard images (Midjourney 等で生成したキービジュアル)
# プロンプト markdown は git 管理、生成画像は容量が大きく個人手元保管推奨。
marketing/storyboard/
marketing/**/*.png
marketing/**/*.jpg
marketing/**/*.jpeg
marketing/**/*.webp
marketing/**/*.mp4
marketing/**/*.mov
